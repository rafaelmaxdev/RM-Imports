# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Mercado Pago
VITE_MP_PUBLIC_KEY=your-public-key
MP_ACCESS_TOKEN=your-access-token
MP_WEBHOOK_SECRET=your-webhook-secret

# Supabase Service Role (used in API routes only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 (image storage)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key

# WhatsApp
VITE_WHATSAPP_NUMBER=5511999999999
VITE_WHATSAPP_SUPPORT=5511999999999

# Cron (optional — for auto-cancel endpoint)
CRON_SECRET=your-cron-secret
